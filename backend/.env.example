APP_NAME=FinPilot AI
DEBUG=true

DATABASE_URL=postgresql+asyncpg://finpilot:finpilot@localhost:5432/finpilot_db

# JWT signing key (not an API key). Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-random-32-byte-hex
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# LLM — pick one provider
LLM_PROVIDER=gemini
LLM_MODEL=gemini-1.5-flash
GEMINI_API_KEY=your-gemini-api-key

# OPENAI_API_KEY=sk-...
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini

REDIS_URL=redis://localhost:6379
